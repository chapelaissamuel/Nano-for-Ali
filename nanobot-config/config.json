{
  "agents": {
    "defaults": {
      "model": "openrouter/google/gemma-4-26b-a4b-it",
      "provider": "openrouter",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.1,
      "maxToolIterations": 200,
      "timezone": "Europe/Paris"
    }
  },
  "providers": {
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "apiBase": "https://openrouter.ai/api/v1"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["*"],
      "streaming": true,
      "sendProgress": true,
      "sendToolHints": false,
      "groupPolicy": "mention"
    }
  }
}
